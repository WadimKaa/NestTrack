<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="512dp"
    android:height="512dp"
    android:viewportWidth="100"
    android:viewportHeight="100">

    <!-- Фоновый светло-фиолетовый круг (диаметр 72) -->
    <path
        android:fillColor="#F0E8FF"
        android:pathData="M 50,50 m -36,0 a 36,36 0 1,1 72,0 a 36,36 0 1,1 -72,0" />

    <!-- Внутренние сегменты щита (сгруппированы с маской обрезки) -->
    <group>
        <clip-path
            android:pathData="M 50,26 C 56,28 63,28 69,33 C 69,47 64,64 50,73 C 36,64 31,47 31,33 C 37,28 44,28 50,26 Z" />

        <!-- Верхний левый сегмент -->
        <path
            android:fillColor="#D9C9FF"
            android:pathData="M 0,0 L 50,0 L 50,50 L 0,50 Z" />

        <!-- Верхний правый сегмент -->
        <path
            android:fillColor="#C2AEFF"
            android:pathData="M 50,0 L 100,0 L 100,50 L 50,50 Z" />

        <!-- Нижний левый сегмент -->
        <path
            android:fillColor="#C2AEFF"
            android:pathData="M 0,50 L 50,50 L 50,100 L 0,100 Z" />

        <!-- Нижний правый сегмент -->
        <path
            android:fillColor="#F5F0FF"
            android:pathData="M 50,50 L 100,50 L 100,100 L 50,100 Z" />
    </group>

    <!-- Внешний плотный контур щита -->
    <path
        android:strokeColor="#7043F6"
        android:strokeWidth="4.5"
        android:strokeLineJoin="round"
        android:strokeLineCap="round"
        android:pathData="M 50,26 C 56,28 63,28 69,33 C 69,47 64,64 50,73 C 36,64 31,47 31,33 C 37,28 44,28 50,26 Z" />

</vector>